#include <stdio.h>

void update(int *a,int *b) {
    
     int temp = *a; // Store original value of a
    *a = *a + *b;  // Update a to sum
    *b = abs(temp - *b); // Update b to absolute difference  
}

int main() {
    int a, b;
    int *pa = &a, *pb = &b;
    
    scanf("%d %d", &a, &b);
    update(pa, pb);
    printf("%d\n%d", a, b);

    return 0;
}

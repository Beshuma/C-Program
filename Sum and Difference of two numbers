#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main()
{
	int a, b;
    float c, d;

    // Read input from stdin
    scanf("%d %d", &a, &b);
    scanf("%f %f", &c, &d);

    // Print integer sum and difference
    printf("%d %d\n", a + b, a - b);

    // Print float sum and difference, rounded to one decimal place
    printf("%.1f %.1f\n", c + d, c - d);

    
    return 0;
}

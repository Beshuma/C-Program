#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() 
{
  
    char ch;
    char s[100];
    char sen[100];

    // Read character
    scanf("%c", &ch);
    // Read word
    scanf("%s", s);
    // Read sentence (using space before % to consume whitespace)
    scanf(" %[^\n]s", sen);

    // Print output
    printf("%c\n", ch);
    printf("%s\n", s);
    printf("%s\n", sen);
 
    return 0;
}

#include <stdio.h>


int main() {
    int a, b, c, d;
    scanf("%d %d %d %d", &a, &b, &c, &d);
    int ans = max_of_four(a, b, c, d);
    printf("%d", ans);
    
    return 0;
}
int max_of_four(int a, int b, int c, int d) {
    /* Start with 'a' as the current maximum */
    int max = a;

    /* Compare with 'b' and update if 'b' is greater */
    if (b > max) {
        max = b;
    }

    /* Compare with 'c' and update if 'c' is greater */
    if (c > max) {
        max = c;
    }

    /* Compare with 'd' and update if 'd' is greater */
    if (d > max) {
        max = d;
    }

    /* Return the final maximum value */
    return max;
}
